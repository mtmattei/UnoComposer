<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <!-- Semantic surfaces -->
      <SolidColorBrush x:Key="DeskBrush" Color="#EBE4D1" />
      <SolidColorBrush x:Key="NotepadSurfaceBrush" Color="#FBFAF5" />
      <SolidColorBrush x:Key="PanelBrush" Color="#F5F5F5" />
      <SolidColorBrush x:Key="HairlineBrush" Color="#ECECEC" />
      <SolidColorBrush x:Key="HairlineStrongBrush" Color="#D8D8D8" />

      <!-- Action / accents -->
      <SolidColorBrush x:Key="ActionBrush" Color="#2F6F68" />
      <SolidColorBrush x:Key="ActionSoftBrush" Color="#EAF3F1" />
      <SolidColorBrush x:Key="OnActionBrush" Color="#FFFFFF" />

      <SolidColorBrush x:Key="InfoBrush" Color="#3D6F9A" />
      <SolidColorBrush x:Key="SuccessBrush" Color="#6F8068" />
      <SolidColorBrush x:Key="WarnBrush" Color="#B04534" />
      <SolidColorBrush x:Key="TagBrush" Color="#7D4FA0" />

      <!-- Ink scale (body to placeholders) -->
      <SolidColorBrush x:Key="InkBrush" Color="#1A1A1A" />
      <SolidColorBrush x:Key="Ink2Brush" Color="#3A3A3A" />
      <SolidColorBrush x:Key="Ink3Brush" Color="#737373" />
      <SolidColorBrush x:Key="Ink4Brush" Color="#A3A3A3" />
      <SolidColorBrush x:Key="Ink5Brush" Color="#C7C7C7" />

      <!-- Foreground on InkBrush surface (primary action button text). -->
      <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FAFAFA" />

      <!-- Code block -->
      <SolidColorBrush x:Key="CodeDarkSurfaceBrush" Color="#1A1B1F" />
      <SolidColorBrush x:Key="CodeDarkForegroundBrush" Color="#E4E4E4" />
      <SolidColorBrush x:Key="CodeKeywordBrush" Color="#E29B5C" />
      <SolidColorBrush x:Key="CodeStringBrush" Color="#A4C97D" />
      <SolidColorBrush x:Key="CodeCommentBrush" Color="#7A7E85" />
      <SolidColorBrush x:Key="CodeTypeBrush" Color="#7AB3DF" />

      <!-- Diff highlight -->
      <SolidColorBrush x:Key="DiffSoftBrush" Color="#EAF3F1" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="DeskBrush" Color="#1A1916" />
      <SolidColorBrush x:Key="NotepadSurfaceBrush" Color="#0C0D0F" />
      <SolidColorBrush x:Key="PanelBrush" Color="#16181C" />
      <SolidColorBrush x:Key="HairlineBrush" Color="#1F1F1F" />
      <SolidColorBrush x:Key="HairlineStrongBrush" Color="#2C2C2C" />

      <SolidColorBrush x:Key="ActionBrush" Color="#7FCAC1" />
      <SolidColorBrush x:Key="ActionSoftBrush" Color="#142B29" />
      <SolidColorBrush x:Key="OnActionBrush" Color="#0C0D0F" />

      <SolidColorBrush x:Key="InfoBrush" Color="#7AB3DF" />
      <SolidColorBrush x:Key="SuccessBrush" Color="#9BBF9D" />
      <SolidColorBrush x:Key="WarnBrush" Color="#E87F6D" />
      <SolidColorBrush x:Key="TagBrush" Color="#B288C4" />

      <SolidColorBrush x:Key="InkBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="Ink2Brush" Color="#CFCFCF" />
      <SolidColorBrush x:Key="Ink3Brush" Color="#7A7A7A" />
      <SolidColorBrush x:Key="Ink4Brush" Color="#5A5A5A" />
      <SolidColorBrush x:Key="Ink5Brush" Color="#444444" />

      <SolidColorBrush x:Key="OnPrimaryBrush" Color="#1A1A1A" />

      <SolidColorBrush x:Key="CodeDarkSurfaceBrush" Color="#0C0D0F" />
      <SolidColorBrush x:Key="CodeDarkForegroundBrush" Color="#E4E4E4" />
      <SolidColorBrush x:Key="CodeKeywordBrush" Color="#E29B5C" />
      <SolidColorBrush x:Key="CodeStringBrush" Color="#A4C97D" />
      <SolidColorBrush x:Key="CodeCommentBrush" Color="#7A7E85" />
      <SolidColorBrush x:Key="CodeTypeBrush" Color="#7AB3DF" />

      <SolidColorBrush x:Key="DiffSoftBrush" Color="#142B29" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
