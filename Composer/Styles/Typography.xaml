<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Font families. Satoshi / Inter / JetBrains Mono fall back gracefully to system fonts. -->
  <FontFamily x:Key="HeaderFontFamily">ms-appx:///Assets/Fonts/Satoshi-Variable.ttf#Satoshi Variable</FontFamily>
  <FontFamily x:Key="UIFontFamily">ms-appx:///Assets/Fonts/Satoshi-Variable.ttf#Satoshi Variable</FontFamily>
  <FontFamily x:Key="BodyFontFamily">Inter, Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
  <FontFamily x:Key="MonoFontFamily">JetBrains Mono, Cascadia Mono, Consolas, monospace</FontFamily>

  <!-- ============================================================
       Composer-specific TextBlock styles (named per Material scale)
       ============================================================ -->

  <Style x:Key="DisplaySmallText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource HeaderFontFamily}" />
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="32" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Foreground" Value="{ThemeResource InkBrush}" />
  </Style>

  <Style x:Key="HeadlineSmallText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource HeaderFontFamily}" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="24" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Foreground" Value="{ThemeResource InkBrush}" />
  </Style>

  <Style x:Key="TitleMediumText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource HeaderFontFamily}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="22" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Foreground" Value="{ThemeResource InkBrush}" />
  </Style>

  <Style x:Key="BodyLargeText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="LineHeight" Value="22" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Foreground" Value="{ThemeResource InkBrush}" />
  </Style>

  <Style x:Key="BodyMediumText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Foreground" Value="{ThemeResource InkBrush}" />
  </Style>

  <Style x:Key="BodySmallText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="LineHeight" Value="18" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Foreground" Value="{ThemeResource Ink2Brush}" />
  </Style>

  <Style x:Key="LabelLargeText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource HeaderFontFamily}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="18" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    <Setter Property="Foreground" Value="{ThemeResource InkBrush}" />
  </Style>

  <Style x:Key="MonoLabelText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="16" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    <Setter Property="Foreground" Value="{ThemeResource InkBrush}" />
  </Style>

  <Style x:Key="MonoBodyText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    <Setter Property="Foreground" Value="{ThemeResource Ink2Brush}" />
  </Style>

  <!-- Eyebrows: compact Satoshi UI labels with restrained tracking. -->
  <Style x:Key="EyebrowText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource UIFontFamily}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="40" />
    <Setter Property="Foreground" Value="{ThemeResource Ink3Brush}" />
  </Style>

  <Style x:Key="EyebrowTinyText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource UIFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="50" />
    <Setter Property="Foreground" Value="{ThemeResource Ink3Brush}" />
  </Style>

  <!-- Italic editorial accent for annotation bodies + acknowledgements. -->
  <Style x:Key="AnnotationText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontStyle" Value="Italic" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Foreground" Value="{ThemeResource Ink2Brush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style x:Key="RecapText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontStyle" Value="Italic" />
    <Setter Property="Foreground" Value="{ThemeResource Ink3Brush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

</ResourceDictionary>
