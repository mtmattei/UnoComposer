<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Fukasawa motion tokens. The brief calls for two cubic-beziers — WinUI's
       built-in eases that approximate them:
       - settle  = cubic-bezier(0.22, 1, 0.36, 1)  → QuinticEase EaseOut
       - breath  = cubic-bezier(0.45, 0, 0.55, 1)  → SineEase EaseInOut
       See docs/composer-delta-brief.md §3. -->

  <QuinticEase x:Key="SettleEase" EasingMode="EaseOut" />
  <SineEase    x:Key="BreathEase" EasingMode="EaseInOut" />

  <!-- Standard durations, named per the delta brief table. -->
  <x:Double x:Key="NotepadSettleMs">720</x:Double>
  <x:Double x:Key="CanvasSettleMs">520</x:Double>
  <x:Double x:Key="RecapArriveMs">640</x:Double>
  <x:Double x:Key="RecapArriveDelayMs">280</x:Double>
  <x:Double x:Key="ChipArriveMs">380</x:Double>
  <x:Double x:Key="ChipStaggerMs">40</x:Double>
  <x:Double x:Key="ButtonHoverMs">200</x:Double>
  <x:Double x:Key="ButtonPressMs">80</x:Double>
  <x:Double x:Key="StackNudgeMs">320</x:Double>
  <x:Double x:Key="ChevronRotateMs">320</x:Double>
  <x:Double x:Key="BreathPulseMs">4200</x:Double>
  <x:Double x:Key="DiagramLeanMs">280</x:Double>
  <x:Double x:Key="AckArriveMs">420</x:Double>
  <x:Double x:Key="RailsRevealMs">480</x:Double>

</ResourceDictionary>
