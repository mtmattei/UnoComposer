<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Composer.Presentation.Controls"
    xmlns:p="using:Composer.Presentation"
    xmlns:utu="using:Uno.Toolkit.UI">

    <p:RuntimeKindToDisplayNameConverter x:Key="RuntimeKindToDisplayNameConverter" />
    <p:RuntimeKindToShortGlyphConverter  x:Key="RuntimeKindToShortGlyphConverter" />
    <p:RuntimeKindIsPreviewToVisibilityConverter   x:Key="RuntimeKindIsPreviewVis" />
    <p:RuntimeKindIsLegacyToVisibilityConverter    x:Key="RuntimeKindIsLegacyVis" />
    <p:RuntimeKindIsNotLegacyToVisibilityConverter x:Key="RuntimeKindIsNotLegacyVis" />

    <Style TargetType="controls:RuntimeChip">
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource InkBrush}" />
        <Setter Property="FocusVisualPrimaryThickness" Value="2" />
        <Setter Property="FocusVisualMargin" Value="-2" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Foreground" Value="{ThemeResource Ink2Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource HairlineBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:RuntimeChip">
                    <Grid x:Name="PartRoot" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="PartRootScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>

                        <!-- Two stacked borders so selection cross-fades smoothly.
                             For legacy runtimes (Net9), the solid border is hidden
                             and a Rectangle overlay draws a dashed outline instead. -->
                        <Border x:Name="UnselectedBg"
                                Background="Transparent"
                                BorderBrush="{ThemeResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Opacity="1"
                                Visibility="{Binding RuntimeKind, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RuntimeKindIsNotLegacyVis}}">
                            <Border Padding="12,7" Background="Transparent">
                                <TextBlock Text="{Binding RuntimeKind, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RuntimeKindToDisplayNameConverter}}"
                                           FontFamily="{StaticResource UIFontFamily}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           CharacterSpacing="0"
                                           Foreground="{ThemeResource Ink2Brush}"
                                           VerticalAlignment="Center"
                                           Opacity="0" />
                            </Border>
                        </Border>

                        <!-- Legacy / deprecating runtime — dashed outline.
                             Visible only when RuntimeKind.IsLegacy() (Net9 today). -->
                        <Grid x:Name="LegacyDashedBg"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Visibility="{Binding RuntimeKind, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RuntimeKindIsLegacyVis}}">
                            <Rectangle x:Name="LegacyDashStroke"
                                       Stroke="{ThemeResource Ink3Brush}"
                                       StrokeThickness="1"
                                       StrokeDashArray="3,2"
                                       RadiusX="8"
                                       RadiusY="8" />
                            <Border Padding="12,7" Background="Transparent">
                                <TextBlock Text="{Binding RuntimeKind, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RuntimeKindToDisplayNameConverter}}"
                                           FontFamily="{StaticResource UIFontFamily}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           CharacterSpacing="0"
                                           Foreground="{ThemeResource Ink2Brush}"
                                           VerticalAlignment="Center"
                                           Opacity="0" />
                            </Border>
                        </Grid>
                        <Border x:Name="SelectedBg"
                                Background="{ThemeResource InkBrush}"
                                BorderBrush="{ThemeResource InkBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Opacity="0">
                            <Border Padding="12,7" Background="Transparent">
                                <TextBlock Text="{Binding RuntimeKind, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RuntimeKindToDisplayNameConverter}}"
                                           FontFamily="{StaticResource UIFontFamily}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           CharacterSpacing="0"
                                           Foreground="{ThemeResource NotepadSurfaceBrush}"
                                           VerticalAlignment="Center"
                                           Opacity="0" />
                            </Border>
                        </Border>

                        <!-- Single rendered label sits on top — both backings carry -->
                        <!-- a hidden copy purely for layout sizing.                  -->
                        <TextBlock x:Name="PartTextLabel"
                                   Text="{Binding RuntimeKind, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RuntimeKindToDisplayNameConverter}}"
                                   FontFamily="{StaticResource UIFontFamily}"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   CharacterSpacing="0"
                                   Foreground="{ThemeResource Ink2Brush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="12,7" />

                        <!-- Preview badge — overlays the top-right corner for
                             pre-release runtimes (Net11 today). Sits slightly
                             outside the chip bounds so it reads as an attached
                             tag rather than part of the chip body. -->
                        <Border x:Name="PreviewBadge"
                                Background="{ThemeResource TagBrush}"
                                CornerRadius="3"
                                Padding="5,1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-6,-7,0"
                                Visibility="{Binding RuntimeKind, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RuntimeKindIsPreviewVis}}">
                            <TextBlock Text="preview"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="100"
                                       Foreground="{ThemeResource OnPrimaryBrush}" />
                        </Border>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualState x:Name="Unselected">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="UnselectedBg" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="SelectedBg" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PartTextLabel"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.08" Value="{ThemeResource Ink2Brush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="UnselectedBg" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="SelectedBg" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PartTextLabel"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.08" Value="{ThemeResource NotepadSurfaceBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="UnselectedBg.BorderBrush" Value="{ThemeResource InkBrush}" />
                                        <!-- Legacy chip uses the dashed Rectangle as its outline;
                                             tint that on hover too so feedback is consistent. -->
                                        <Setter Target="LegacyDashStroke.Stroke" Value="{ThemeResource Ink2Brush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PartRootScale" Storyboard.TargetProperty="ScaleX"
                                                         To="0.97" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="6" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="PartRootScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.97" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="6" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
