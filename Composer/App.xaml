<Application x:Class="Composer.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utum="using:Uno.Toolkit.UI.Material">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utum:MaterialToolkitTheme
          ColorOverrideSource="ms-appx:///Styles/ColorPaletteOverride.xaml" />
        <!-- Composer-specific resources -->
        <ResourceDictionary Source="ms-appx:///Styles/Brushes.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/Typography.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/ComposerStyles.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/Motion.xaml" />
        <ResourceDictionary Source="ms-appx:///Themes/PlatformChip.xaml" />
        <ResourceDictionary Source="ms-appx:///Themes/RuntimeChip.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
