<UserControl x:Class="Composer.Presentation.Previewers.DataPreviewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Spacing="14">
    <TextBlock Style="{StaticResource HeadlineSmallText}" Text="Data Contracts" />

    <TextBlock Style="{StaticResource EyebrowText}" Text="ENTITIES" Margin="0,4,0,0" />
    <Border Background="{ThemeResource CodeDarkSurfaceBrush}" CornerRadius="6" Padding="14,10">
      <TextBlock x:Name="Entity1Block"
                 FontFamily="{StaticResource MonoFontFamily}"
                 FontSize="11"
                 LineHeight="18"
                 Foreground="{ThemeResource CodeDarkForegroundBrush}" />
    </Border>
    <Border Background="{ThemeResource CodeDarkSurfaceBrush}" CornerRadius="6" Padding="14,10">
      <TextBlock x:Name="Entity2Block"
                 FontFamily="{StaticResource MonoFontFamily}"
                 FontSize="11"
                 LineHeight="18"
                 Foreground="{ThemeResource CodeDarkForegroundBrush}" />
    </Border>
    <Border Background="{ThemeResource CodeDarkSurfaceBrush}" CornerRadius="6" Padding="14,10">
      <TextBlock x:Name="ScheduleBlock"
                 FontFamily="{StaticResource MonoFontFamily}"
                 FontSize="11"
                 LineHeight="18"
                 Foreground="{ThemeResource CodeDarkForegroundBrush}" />
    </Border>

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0"
            Padding="14,2,0,0" Margin="0,4,0,0">
      <StackPanel Spacing="4">
        <TextBlock Style="{StaticResource EyebrowTinyText}" Text="WHY THESE SHAPES" />
        <TextBlock x:Name="WhyTheseShapesText" Style="{StaticResource AnnotationText}" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
