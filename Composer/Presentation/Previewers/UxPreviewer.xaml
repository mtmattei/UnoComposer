<UserControl x:Class="Composer.Presentation.Previewers.UxPreviewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Spacing="14">
    <TextBlock Style="{StaticResource HeadlineSmallText}" Text="UX Flows" />
    <TextBlock Style="{StaticResource BodySmallText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="Five screens in sequence. Each card maps to a discrete user task." />

    <TextBlock x:Name="FlowEyebrow" Style="{StaticResource EyebrowText}" Margin="0,4,0,0" />
    <StackPanel Spacing="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="Row0Name"    Style="{StaticResource LabelLargeText}" />
        <TextBlock x:Name="Row0Caption" Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Foreground="{ThemeResource Ink3Brush}" />
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="Row1Name"    Style="{StaticResource LabelLargeText}" />
        <TextBlock x:Name="Row1Caption" Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Foreground="{ThemeResource Ink3Brush}" />
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="Row2Name"    Style="{StaticResource LabelLargeText}" />
        <TextBlock x:Name="Row2Caption" Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Foreground="{ThemeResource Ink3Brush}" />
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="Row3Name"    Style="{StaticResource LabelLargeText}" />
        <TextBlock x:Name="Row3Caption" Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Foreground="{ThemeResource Ink3Brush}" />
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="Row4Name"    Style="{StaticResource LabelLargeText}" />
        <TextBlock x:Name="Row4Caption" Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Foreground="{ThemeResource SuccessBrush}" />
      </Grid>
    </StackPanel>

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0"
            Padding="14,2,0,0" Margin="0,4,0,0">
      <StackPanel Spacing="4">
        <TextBlock Style="{StaticResource EyebrowTinyText}" Text="WHY THIS FLOW" />
        <TextBlock x:Name="WhyThisFlowText" Style="{StaticResource AnnotationText}" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
