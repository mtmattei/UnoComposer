<UserControl x:Class="Composer.Presentation.Previewers.IntentPreviewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Spacing="14">
    <TextBlock Style="{StaticResource HeadlineSmallText}" Text="Intent" />
    <TextBlock Style="{StaticResource BodySmallText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="The shape of what we're building, before any code." />

    <StackPanel Spacing="10">
      <TextBlock Style="{StaticResource EyebrowText}" Text="SUMMARY" />
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="92" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}" Text="App type" />
        <TextBlock Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Text="{Binding Intent.AppType}" TextWrapping="Wrap" />
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="92" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}" Text="Primary user" />
        <TextBlock Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Text="{Binding Intent.PrimaryUser}" TextWrapping="Wrap" />
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="92" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}" Text="Workflow" />
        <TextBlock Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Text="{Binding Intent.Workflow}" TextWrapping="Wrap" />
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="92" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}" Text="Platforms" />
        <TextBlock Grid.Column="1" Style="{StaticResource BodySmallText}"
                   Text="{Binding Intent.Platforms}" TextWrapping="Wrap" />
      </Grid>
    </StackPanel>
  </StackPanel>
</UserControl>
