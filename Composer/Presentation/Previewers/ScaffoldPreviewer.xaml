<UserControl x:Class="Composer.Presentation.Previewers.ScaffoldPreviewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvux="using:Uno.Extensions.Reactive.UI">
  <StackPanel Spacing="14">
    <TextBlock Style="{StaticResource HeadlineSmallText}" Text="Scaffold" />
    <TextBlock Style="{StaticResource BodySmallText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="Eight composed files into a synthesised prompt-and-command bundle for your agent." />

    <TextBlock Style="{StaticResource EyebrowText}" Text="BUNDLE CONTENTS" Margin="0,4,0,0" />
    <Border Background="{ThemeResource CodeDarkSurfaceBrush}" CornerRadius="6" Padding="14,10">
      <mvux:FeedView Source="{Binding BundleTree}">
        <mvux:FeedView.ValueTemplate>
          <DataTemplate>
            <TextBlock FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="11"
                       LineHeight="18"
                       Foreground="{ThemeResource CodeDarkForegroundBrush}"
                       Text="{Binding Data}" />
          </DataTemplate>
        </mvux:FeedView.ValueTemplate>
      </mvux:FeedView>
    </Border>

    <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap" Text="The composition is, for now, complete." />
  </StackPanel>
</UserControl>
