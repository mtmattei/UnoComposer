<UserControl x:Class="Composer.Presentation.Layers.ComposerFooter"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border BorderBrush="{ThemeResource HairlineStrongBrush}"
          BorderThickness="0,2,0,0"
          Padding="0,24,0,4">
    <StackPanel>
    <StackPanel x:Name="RefinementPanel"
                Opacity="1">
      <StackPanel.RenderTransform>
        <TranslateTransform x:Name="RefinementPanelTransform" />
      </StackPanel.RenderTransform>

      <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
        <TextBlock Style="{StaticResource EyebrowText}" Text="COMPOSER" />
        <TextBlock Style="{StaticResource BodySmallText}"
                   Foreground="{ThemeResource Ink4Brush}"
                   Text="·" />
        <TextBlock Style="{StaticResource EyebrowText}" Text="REFINING" />
      </StackPanel>

      <TextBlock x:Name="QuestionText"
                 Style="{StaticResource BodyLargeText}"
                 Foreground="{ThemeResource InkBrush}"
                 TextWrapping="Wrap"
                 VerticalAlignment="Top"
                 Margin="0,0,0,8" />

      <TextBox Style="{StaticResource ComposerTextBoxStyle}"
               PlaceholderText="Refine, or accept what's drawn..."
               Text="{Binding ComposerPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               TextChanged="OnComposerPromptChanged"
               Margin="0,0,0,14" />

      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Style="{StaticResource EyebrowText}"
                     Text="TRY"
                     VerticalAlignment="Center"
                     Margin="0,0,2,0" />
          <StackPanel x:Name="ChipsHost"
                      Orientation="Horizontal"
                      Spacing="8"
                      VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Column="1"
                   Style="{StaticResource EyebrowText}"
                   Foreground="{ThemeResource Ink4Brush}"
                   Text="⌘↵ TO SUBMIT"
                   VerticalAlignment="Center" />
      </Grid>

      <StackPanel x:Name="MissingSectionsRow"
                  Orientation="Horizontal"
                  Spacing="14"
                  Margin="0,0,0,16"
                  Visibility="Collapsed">
        <TextBlock Style="{StaticResource EyebrowTinyText}"
                   Foreground="{ThemeResource Ink4Brush}"
                   Text="STILL MISSING"
                   VerticalAlignment="Center"
                   Margin="0,0,2,0" />
        <StackPanel x:Name="MissingChipsHost"
                    Orientation="Horizontal"
                    Spacing="14"
                    VerticalAlignment="Center" />
      </StackPanel>
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="14">
      <Button x:Name="ContinueBtn"
              Style="{StaticResource PrimaryActionButtonStyle}"
              Content="Continue →"
              Command="{Binding LockAndContinue}"
              Visibility="Visible" />

      <Button x:Name="GenerateBtn"
              Style="{StaticResource PrimaryActionButtonStyle}"
              Command="{Binding GeneratePreview}"
              Visibility="Collapsed">
        <TextBlock x:Name="GenerateLabel" Text="Generate preview →" />
      </Button>

      <Button x:Name="AcceptBtn"
              Style="{StaticResource PrimaryActionButtonStyle}"
              Command="{Binding AcceptAndLock}"
              Visibility="Collapsed">
        <TextBlock x:Name="AcceptLabel" Text="Accept and lock →" />
      </Button>

      <Button x:Name="DiscardBtn"
              Style="{StaticResource LinkButtonStyle}"
              Content="Discard"
              Command="{Binding DiscardPreview}"
              VerticalAlignment="Center"
              Visibility="Collapsed" />
    </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
