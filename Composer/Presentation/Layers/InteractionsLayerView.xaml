<UserControl x:Class="Composer.Presentation.Layers.InteractionsLayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Composer.Presentation"
             xmlns:layers="using:Composer.Presentation.Layers"
             xmlns:diagrams="using:Composer.Presentation.Diagrams"
             xmlns:mvux="using:Uno.Extensions.Reactive.UI">

  <UserControl.Resources>
    <local:FlowTabStyleConverter x:Key="FlowTabStyle" />
  </UserControl.Resources>

  <StackPanel Spacing="0">
    <TextBlock Style="{StaticResource RecapText}"
               Text="↳ Inter body, action #c89c3f, low-chroma palette."
               Margin="0,0,0,18" />

    <Grid Margin="0,0,0,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Ellipse Width="6" Height="6" Fill="{ThemeResource ActionBrush}" VerticalAlignment="Center" />
        <TextBlock Style="{StaticResource EyebrowText}" Text="05 · INTERACTIONS" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Style="{StaticResource EyebrowText}"
                 Foreground="{ThemeResource Ink4Brush}"
                 Text="05 / 08" />
    </Grid>

    <TextBlock Style="{StaticResource DisplaySmallText}"
               Text="What about every state, every flow?"
               Margin="0,0,0,12" />

    <TextBlock Style="{StaticResource BodyLargeText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="Six states the primary flow can rest in. Click around to see what each one means."
               Margin="0,0,0,24" />

    <!-- Flow switcher — primary label contextualizes from intent; tabs are clickable -->
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,18">
      <Button Style="{Binding ActiveFlowIndex, Converter={StaticResource FlowTabStyle}, ConverterParameter=0}"
              Content="{Binding PrimaryFlowLabel}"
              Command="{Binding SetActiveFlow}">
        <Button.CommandParameter><x:Int32>0</x:Int32></Button.CommandParameter>
      </Button>
      <Button Style="{Binding ActiveFlowIndex, Converter={StaticResource FlowTabStyle}, ConverterParameter=1}"
              Content="Sign in"
              Command="{Binding SetActiveFlow}">
        <Button.CommandParameter><x:Int32>1</x:Int32></Button.CommandParameter>
      </Button>
      <Button Style="{Binding ActiveFlowIndex, Converter={StaticResource FlowTabStyle}, ConverterParameter=2}"
              Content="Sync data"
              Command="{Binding SetActiveFlow}">
        <Button.CommandParameter><x:Int32>2</x:Int32></Button.CommandParameter>
      </Button>
    </StackPanel>

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,20" />

    <!-- Interactions state pill timeline -->
    <Border Background="{ThemeResource NotepadSurfaceBrush}" CornerRadius="8" Padding="0">
      <diagrams:InteractionsStateView />
    </Border>

    <!-- Active state detail panel -->
    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0"
            Padding="16,4,0,4" Margin="0,28,0,12">
      <StackPanel Spacing="4">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="DEFAULT STATE" />
          <TextBlock Style="{StaticResource EyebrowTinyText}" Foreground="{ThemeResource Ink4Brush}" Text="·" />
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="ACTIVE" />
        </StackPanel>
        <TextBlock x:Name="DefaultStateAnnotation" Style="{StaticResource AnnotationText}" />
      </StackPanel>
    </Border>

    <layers:ComposerFooter Margin="0,16,0,0" />
  </StackPanel>
</UserControl>
