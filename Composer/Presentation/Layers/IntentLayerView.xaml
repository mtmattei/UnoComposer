<UserControl x:Class="Composer.Presentation.Layers.IntentLayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layers="using:Composer.Presentation.Layers"
             xmlns:controls="using:Composer.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI">

  <StackPanel Spacing="0">

    <TextBlock Style="{StaticResource DisplaySmallText}"
               Text="What are we building?"
               Margin="0,4,0,7" />

    <TextBlock Style="{StaticResource BodyLargeText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="A single brief — eight composed files plus a working dotnet command — for your agent to scaffold from. Start here."
               Margin="0,0,0,32" />

    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16" VerticalAlignment="Center">
      <TextBlock Style="{StaticResource MonoLabelText}" Text="01 / 08" VerticalAlignment="Center" />
      <TextBlock Style="{StaticResource BodySmallText}"
                 Foreground="{ThemeResource Ink4Brush}"
                 Text="·"
                 VerticalAlignment="Center" />
      <TextBlock Style="{StaticResource MonoLabelText}" Text="intent.md" VerticalAlignment="Center" />
      <TextBlock Style="{StaticResource BodySmallText}"
                 Foreground="{ThemeResource Ink4Brush}"
                 Text="·"
                 VerticalAlignment="Center" />
      <TextBlock Style="{StaticResource EyebrowText}"
                 Text="EDITING"
                 VerticalAlignment="Center"
                 Margin="0,1,0,0" />
    </StackPanel>

    <Border BorderBrush="{ThemeResource HairlineBrush}"
            BorderThickness="0,1,0,0"
            Margin="0,0,0,16" />

    <Grid Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Style="{StaticResource EyebrowText}" Text="APP TYPE" VerticalAlignment="Center" />
      <TextBox Grid.Column="1"
               Style="{StaticResource IntentFieldTextBoxStyle}"
               Text="{Binding AppType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               TextChanged="OnIntentFieldTextChanged" />
    </Grid>
    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,2,0,8" />

    <Grid Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Style="{StaticResource EyebrowText}" Text="PRIMARY USER" VerticalAlignment="Center" />
      <TextBox Grid.Column="1"
               Style="{StaticResource IntentFieldTextBoxStyle}"
               Text="{Binding PrimaryUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               TextChanged="OnIntentFieldTextChanged" />
    </Grid>
    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,2,0,8" />

    <Grid Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Style="{StaticResource EyebrowText}" Text="WORKFLOW" VerticalAlignment="Center" />
      <TextBox Grid.Column="1"
               Style="{StaticResource IntentFieldTextBoxStyle}"
               Text="{Binding Workflow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               TextChanged="OnIntentFieldTextChanged" />
    </Grid>
    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,2,0,14" />

    <Grid Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Style="{StaticResource EyebrowText}" Text="PLATFORMS" VerticalAlignment="Center" />
      <utu:AutoLayout Grid.Column="1" Orientation="Horizontal" Spacing="8" PrimaryAxisAlignment="Start">
        <controls:PlatformChip x:Name="WebChip"     PlatformKind="Web"     Command="{Binding TogglePlatform}" />
        <controls:PlatformChip x:Name="WindowsChip" PlatformKind="Windows" Command="{Binding TogglePlatform}" />
        <controls:PlatformChip x:Name="AndroidChip" PlatformKind="Android" Command="{Binding TogglePlatform}" />
        <controls:PlatformChip x:Name="IOSChip"     PlatformKind="iOS"     Command="{Binding TogglePlatform}" />
        <controls:PlatformChip x:Name="DesktopChip" PlatformKind="Desktop" Command="{Binding TogglePlatform}" />
      </utu:AutoLayout>
    </Grid>
    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,2,0,12" />

    <Grid Margin="0,0,0,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Style="{StaticResource EyebrowText}" Text="RUNTIME" VerticalAlignment="Center" />
      <utu:AutoLayout Grid.Column="1" Orientation="Horizontal" Spacing="8" PrimaryAxisAlignment="Start">
        <controls:RuntimeChip x:Name="Net11Chip" RuntimeKind="Net11" Command="{Binding SetRuntime}" />
        <controls:RuntimeChip x:Name="Net10Chip" RuntimeKind="Net10" Command="{Binding SetRuntime}" />
        <controls:RuntimeChip x:Name="Net9Chip"  RuntimeKind="Net9"  Command="{Binding SetRuntime}" />
      </utu:AutoLayout>
    </Grid>

    <Border x:Name="HandoffRow"
            BorderBrush="{ThemeResource HairlineBrush}"
            BorderThickness="0,1,0,0"
            Padding="0,10,0,0"
            Margin="0,8,0,0"
            Visibility="{Binding ExampleVisible, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="120" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource EyebrowTinyText}"
                   Text="HANDOFF"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <TextBlock Style="{StaticResource BodySmallText}"
                     Foreground="{ThemeResource Ink3Brush}"
                     Text="8 files + scaffold command"
                     VerticalAlignment="Center" />
          <Button Style="{StaticResource LinkButtonStyle}"
                  Content="Clear"
                  Foreground="{ThemeResource Ink2Brush}"
                  Command="{Binding ClearExample}" />
          <Button Style="{StaticResource LinkButtonStyle}"
                  Content="Hide"
                  Foreground="{ThemeResource Ink3Brush}"
                  Command="{Binding DismissExample}" />
        </StackPanel>
      </Grid>
    </Border>

    <controls:ReferenceScreenshotPanel x:Name="ReferencePanel" Margin="0,18,0,0" />

    <layers:ComposerFooter Margin="0,18,0,0" />

  </StackPanel>
</UserControl>
