<UserControl x:Class="Composer.Presentation.Layers.ImplementationLayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layers="using:Composer.Presentation.Layers">

  <StackPanel Spacing="0">
    <TextBlock x:Name="RecapText"
               Style="{StaticResource RecapText}"
               Margin="0,0,0,18" />

    <Grid Margin="0,0,0,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Ellipse Width="6" Height="6" Fill="{ThemeResource ActionBrush}" VerticalAlignment="Center" />
        <TextBlock Style="{StaticResource EyebrowText}" Text="07 · IMPLEMENTATION" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Style="{StaticResource EyebrowText}"
                 Foreground="{ThemeResource Ink4Brush}"
                 Text="07 / 08" />
    </Grid>

    <TextBlock Style="{StaticResource DisplaySmallText}"
               Text="How does it get built?"
               Margin="0,0,0,12" />

    <TextBlock Style="{StaticResource BodyLargeText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="Six phases in a natural order. Plan, file dependencies, agent prompts."
               Margin="0,0,0,28" />

    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
      <TextBlock Style="{StaticResource MonoLabelText}" Text="implementation-plan.md" />
      <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink4Brush}" Text="·" />
      <TextBlock Style="{StaticResource EyebrowText}" Text="LOCKED CONTEXT" />
    </StackPanel>

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,18" />

    <!-- Phase rows -->
    <StackPanel Spacing="0">
      <!-- P1 -->
      <Grid Padding="0,16" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="46" />
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource MonoLabelText}" Foreground="{ThemeResource WarnBrush}" Text="P1" />
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Foreground="{ThemeResource WarnBrush}" Text="SCAFFOLD" />
          <TextBlock Style="{StaticResource LabelLargeText}" Text="Solution skeleton" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Style="{StaticResource BodyMediumText}" Foreground="{ThemeResource Ink2Brush}" TextWrapping="Wrap" Text="Multi-head Uno solution with MVUX + Uno.Extensions." />
          <TextBlock Style="{StaticResource MonoBodyText}" Foreground="{ThemeResource Ink3Brush}" Text=".sln, Composer/*, Mobile, Desktop, Wasm" />
        </StackPanel>
        <Border Grid.Column="3" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0" Padding="14,2,0,0">
          <TextBlock Style="{StaticResource AnnotationText}" Foreground="{ThemeResource Ink2Brush}" Text="Use dotnet new unoapp with recommended preset, target net10.0, presentation mvux, theme material." />
        </Border>
      </Grid>

      <!-- P2 -->
      <Grid Padding="0,16" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="46" />
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource MonoLabelText}" Foreground="{ThemeResource InfoBrush}" Text="P2" />
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Foreground="{ThemeResource InfoBrush}" Text="SHELL" />
          <TextBlock Style="{StaticResource LabelLargeText}" Text="Shell &amp; navigation" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Style="{StaticResource BodyMediumText}" Foreground="{ThemeResource Ink2Brush}" TextWrapping="Wrap" Text="Two regions: top NavBar and main Frame. Routes registered." />
          <TextBlock Style="{StaticResource MonoBodyText}" Foreground="{ThemeResource Ink3Brush}" Text="Shell.xaml, RouteMap.cs, NavigationViewModel.cs" />
        </StackPanel>
        <Border Grid.Column="3" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0" Padding="14,2,0,0">
          <TextBlock Style="{StaticResource AnnotationText}" Foreground="{ThemeResource Ink2Brush}" Text="All navigation via uen:Navigation.Request — never code-behind." />
        </Border>
      </Grid>

      <!-- P3 -->
      <Grid Padding="0,16" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="46" />
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource MonoLabelText}" Foreground="{ThemeResource TagBrush}" Text="P3" />
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Foreground="{ThemeResource TagBrush}" Text="DOMAIN" />
          <TextBlock Style="{StaticResource LabelLargeText}" Text="Models &amp; feeds" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Style="{StaticResource BodyMediumText}" Foreground="{ThemeResource Ink2Brush}" TextWrapping="Wrap" Text="Domain records, MVUX feed and state for each entity." />
          <TextBlock Style="{StaticResource MonoBodyText}" Foreground="{ThemeResource Ink3Brush}" Text="Models/, Presentation/Models/*Model.cs" />
        </StackPanel>
        <Border Grid.Column="3" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0" Padding="14,2,0,0">
          <TextBlock Style="{StaticResource AnnotationText}" Foreground="{ThemeResource Ink2Brush}" Text="One partial record per entity. Mutations through record with { ... }." />
        </Border>
      </Grid>

      <!-- P4 -->
      <Grid Padding="0,16" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="46" />
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource MonoLabelText}" Foreground="{ThemeResource AccentPinkBrush}" Text="P4" />
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Foreground="{ThemeResource AccentPinkBrush}" Text="SCREENS" />
          <TextBlock Style="{StaticResource LabelLargeText}" Text="Screens &amp; bindings" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock x:Name="ScreensListText" Style="{StaticResource BodyMediumText}" Foreground="{ThemeResource Ink2Brush}" TextWrapping="Wrap" />
          <TextBlock Style="{StaticResource MonoBodyText}" Foreground="{ThemeResource Ink3Brush}" Text="Views/Pages/*.xaml" />
        </StackPanel>
        <Border Grid.Column="3" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0" Padding="14,2,0,0">
          <TextBlock Style="{StaticResource AnnotationText}" Foreground="{ThemeResource Ink2Brush}" Text="x:Bind only. Lightweight styling only." />
        </Border>
      </Grid>

      <!-- P5 -->
      <Grid Padding="0,16" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="46" />
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource MonoLabelText}" Foreground="{ThemeResource SuccessBrush}" Text="P5" />
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Foreground="{ThemeResource SuccessBrush}" Text="STATES" />
          <TextBlock Style="{StaticResource LabelLargeText}" Text="Interaction states" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Style="{StaticResource BodyMediumText}" Foreground="{ThemeResource Ink2Brush}" TextWrapping="Wrap" Text="All six states wired in VisualStateManager across screens." />
          <TextBlock Style="{StaticResource MonoBodyText}" Foreground="{ThemeResource Ink3Brush}" Text="VSM groups, transitions, EmptyState/ErrorState" />
        </StackPanel>
        <Border Grid.Column="3" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0" Padding="14,2,0,0">
          <TextBlock Style="{StaticResource AnnotationText}" Foreground="{ThemeResource Ink2Brush}" Text="Single CommonStates group. Drive transitions via VisualStateManagerExtensions.States binding." />
        </Border>
      </Grid>

      <!-- P6 -->
      <Grid Padding="0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="46" />
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource MonoLabelText}" Foreground="{ThemeResource ActionBrush}" Text="P6" />
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Foreground="{ThemeResource ActionBrush}" Text="POLISH" />
          <TextBlock Style="{StaticResource LabelLargeText}" Text="Tests &amp; accessibility" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Style="{StaticResource BodyMediumText}" Foreground="{ThemeResource Ink2Brush}" TextWrapping="Wrap" Text="Unit tests, MVUX tests, UI tests, contrast and a11y sweep." />
          <TextBlock Style="{StaticResource MonoBodyText}" Foreground="{ThemeResource Ink3Brush}" Text="Composer.Tests/, AutomationProperties" />
        </StackPanel>
        <Border Grid.Column="3" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0" Padding="14,2,0,0">
          <TextBlock Style="{StaticResource AnnotationText}" Foreground="{ThemeResource Ink2Brush}" Text="One scenario per layer happy path, plus reset and revisit." />
        </Border>
      </Grid>
    </StackPanel>

    <layers:ComposerFooter Margin="0,28,0,0" />
  </StackPanel>
</UserControl>
