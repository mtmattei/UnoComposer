<UserControl x:Class="Composer.Presentation.Layers.DataLayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layers="using:Composer.Presentation.Layers">

  <StackPanel Spacing="0">
    <TextBlock Style="{StaticResource RecapText}"
               Text="↳ Interactions snapshots — six states, every flow snaps to one."
               Margin="0,0,0,18" />

    <Grid Margin="0,0,0,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Ellipse Width="6" Height="6" Fill="{ThemeResource ActionBrush}" VerticalAlignment="Center" />
        <TextBlock Style="{StaticResource EyebrowText}" Text="06 · DATA" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Style="{StaticResource EyebrowText}"
                 Foreground="{ThemeResource Ink4Brush}"
                 Text="06 / 08" />
    </Grid>

    <TextBlock Style="{StaticResource DisplaySmallText}"
               Text="What shapes does the data take?"
               Margin="0,0,0,12" />

    <TextBlock x:Name="EntitySummaryText"
               Style="{StaticResource BodyLargeText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Margin="0,0,0,28" />

    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
      <TextBlock Style="{StaticResource MonoLabelText}" Text="data-contracts.cs" />
      <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink4Brush}" Text="·" />
      <TextBlock Style="{StaticResource EyebrowText}" Text="EDITING" />
    </StackPanel>

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,18" />

    <!-- Entity blocks — titles + the technician-id / status field types are
         populated in code-behind from IntentContext so a calorie tracker
         shows Meal + User + Schedule, not Job + Technician + Schedule. -->
    <StackPanel Spacing="22">
      <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock x:Name="Entity1Title" Style="{StaticResource TitleMediumText}" />
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="RECORD" VerticalAlignment="Center" />
        </StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MonoBodyText}" Text="id : string" />
          <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MonoBodyText}" Text="title : string" />
          <TextBlock x:Name="Entity1Field2A" Grid.Row="1" Grid.Column="0" Style="{StaticResource MonoBodyText}" />
          <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MonoBodyText}" Text="scheduledAt : DateTime?" />
          <TextBlock x:Name="Entity1Field3A" Grid.Row="2" Grid.Column="0" Style="{StaticResource MonoBodyText}" />
          <TextBlock x:Name="Entity1Field3B" Grid.Row="2" Grid.Column="1" Style="{StaticResource MonoBodyText}" />
          <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MonoBodyText}" Text="notes : string?" />
          <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MonoBodyText}" Text="syncState : SyncState" />
        </Grid>
      </StackPanel>

      <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" />

      <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock x:Name="Entity2Title" Style="{StaticResource TitleMediumText}" />
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="RECORD" VerticalAlignment="Center" />
        </StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MonoBodyText}" Text="id : string" />
          <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MonoBodyText}" Text="name : string" />
          <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MonoBodyText}" Text="phone : string?" />
          <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MonoBodyText}" Text="available : bool" />
        </Grid>
      </StackPanel>

      <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" />

      <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Style="{StaticResource TitleMediumText}" Text="Schedule" />
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="RECORD" VerticalAlignment="Center" />
        </StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MonoBodyText}" Text="day : DateOnly" />
          <TextBlock x:Name="ScheduleEntityListField" Grid.Row="0" Grid.Column="1" Style="{StaticResource MonoBodyText}" />
        </Grid>
      </StackPanel>
    </StackPanel>

    <!-- Generated C# code block -->
    <Border Background="{ThemeResource CodeDarkSurfaceBrush}"
            CornerRadius="6" Padding="0" Margin="0,28,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="36" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border CornerRadius="6,6,0,0" Background="#16181C">
          <Grid Padding="14,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ModelFilenameText"
                       FontFamily="{StaticResource MonoFontFamily}" FontSize="11" FontWeight="SemiBold"
                       Foreground="#E4E4E4"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Style="{StaticResource EyebrowTinyText}"
                       Foreground="#9DA4AF"
                       Text="GENERATED FROM CANVAS"
                       VerticalAlignment="Center" />
          </Grid>
        </Border>
        <!-- C# record body — inlines populated in code-behind so the entity
             name (record + TechnicianId field) reflect the active intent. -->
        <TextBlock x:Name="ModelBodyText"
                   Grid.Row="1"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="12"
                   LineHeight="20"
                   Padding="16,14"
                   Foreground="#E4E4E4" />
      </Grid>
    </Border>

    <layers:ComposerFooter Margin="0,28,0,0" />
  </StackPanel>
</UserControl>
