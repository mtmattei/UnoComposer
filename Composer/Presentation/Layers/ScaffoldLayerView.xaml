<UserControl x:Class="Composer.Presentation.Layers.ScaffoldLayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layers="using:Composer.Presentation.Layers">

  <StackPanel Spacing="0">
    <TextBlock Style="{StaticResource RecapText}"
               Text="↳ Implementation plan ready — modules wired, data shaped, work sized."
               Margin="0,0,0,18" />

    <Grid Margin="0,0,0,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Ellipse Width="6" Height="6" Fill="{ThemeResource ActionBrush}" VerticalAlignment="Center" />
        <TextBlock Style="{StaticResource EyebrowText}" Text="08 · SCAFFOLD" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Style="{StaticResource EyebrowText}"
                 Foreground="{ThemeResource Ink4Brush}"
                 Text="08 / 08" />
    </Grid>

    <TextBlock Style="{StaticResource DisplaySmallText}"
               Text="The bundle is ready."
               Margin="0,0,0,12" />

    <TextBlock Style="{StaticResource BodyLargeText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="Six phases, scaffold — polish, with explicit dependencies."
               Margin="0,0,0,28" />

    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
      <TextBlock Style="{StaticResource MonoLabelText}" Text="scaffold-command.md" />
      <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink4Brush}" Text="·" />
      <TextBlock Style="{StaticResource EyebrowText}" Text="READY" />
    </StackPanel>

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,18" />

    <!-- Dark code block with the dotnet new unoapp command -->
    <Border Background="{ThemeResource CodeDarkSurfaceBrush}"
            CornerRadius="6" Padding="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="36" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border CornerRadius="6,6,0,0" Background="#16181C">
          <Grid Padding="14,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock FontFamily="{StaticResource MonoFontFamily}" FontSize="11" FontWeight="SemiBold"
                       Foreground="#E4E4E4"
                       VerticalAlignment="Center"
                       Text="scaffold-command.sh" />
            <Button Grid.Column="1" Style="{StaticResource LinkButtonStyle}"
                    Foreground="#9DA4AF" Content="Copy"
                    Click="OnCopyCommandClicked" />
          </Grid>
        </Border>
        <!-- Scaffold command — inlines populated in code-behind so the
             project name (-n flag) and TFM / platforms / features all
             reflect the active intent + chip selections. -->
        <TextBlock x:Name="ScaffoldCommandText"
                   Grid.Row="1"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="12"
                   LineHeight="20"
                   Padding="20,16"
                   Foreground="#E4E4E4" />
      </Grid>
    </Border>

    <!-- Action buttons -->
    <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,28,0,0">
      <Button Style="{StaticResource AccentActionButtonStyle}"
              Content="Download bundle ↓"
              Click="OnDownloadBundleClicked" />
      <Button Style="{StaticResource GhostButtonStyle}"
              BorderThickness="1"
              BorderBrush="{ThemeResource HairlineBrush}"
              Content="Copy prompt-context.md"
              Click="OnCopyPromptContextClicked" />
    </StackPanel>

    <TextBlock x:Name="BundleStatusText"
               Style="{StaticResource AnnotationText}"
               Foreground="{ThemeResource Ink3Brush}"
               Visibility="Collapsed"
               Margin="0,12,0,0"
               Text="" />

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0"
            Margin="0,32,0,0" Padding="0,18,0,0">
      <TextBlock Style="{StaticResource AnnotationText}"
                 Foreground="{ThemeResource Ink3Brush}"
                 HorizontalAlignment="Right"
                 Text="the composition is, for now, complete." />
    </Border>
  </StackPanel>
</UserControl>
