<UserControl x:Class="Composer.Presentation.Layers.ArchitectureLayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layers="using:Composer.Presentation.Layers"
             xmlns:diagrams="using:Composer.Presentation.Diagrams">

  <StackPanel Spacing="0">
    <TextBlock x:Name="RecapText"
               Style="{StaticResource RecapText}"
               Margin="0,0,0,18" />

    <Grid Margin="0,0,0,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Ellipse Width="6" Height="6" Fill="{ThemeResource ActionBrush}" VerticalAlignment="Center" />
        <TextBlock Style="{StaticResource EyebrowText}" Text="03 · ARCHITECTURE" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Style="{StaticResource EyebrowText}"
                 Foreground="{ThemeResource Ink4Brush}"
                 Text="03 / 08" />
    </Grid>

    <TextBlock Style="{StaticResource DisplaySmallText}"
               Text="How is this app shaped?"
               Margin="0,0,0,12" />

    <TextBlock Style="{StaticResource BodyLargeText}"
               Foreground="{ThemeResource Ink3Brush}"
               TextWrapping="Wrap"
               Text="Six modules connect, and the solution tree they imply."
               Margin="0,0,0,28" />

    <Grid Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Style="{StaticResource MonoLabelText}" Text="blueprint.svg" />
        <TextBlock Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink4Brush}" Text="·" />
        <TextBlock Style="{StaticResource EyebrowText}" Text="LOCKED CONTEXT" />
      </StackPanel>
      <Button Grid.Column="1" Style="{StaticResource LinkButtonStyle}" Content="↻ Regenerate" />
    </Grid>

    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,18" />

    <Grid ColumnSpacing="18" RowSpacing="18" Margin="0,0,0,18">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Background="{ThemeResource NotepadSurfaceBrush}" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
        <StackPanel Spacing="6">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="DATA LAYER" />
          <TextBlock x:Name="DataLayerText" Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Background="{ThemeResource NotepadSurfaceBrush}" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
        <StackPanel Spacing="6">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="NAVIGATION TOPOLOGY" />
          <TextBlock x:Name="NavigationTopologyText" Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Background="{ThemeResource NotepadSurfaceBrush}" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
        <StackPanel Spacing="6">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="SOLUTION LAYOUT" />
          <TextBlock x:Name="SolutionLayoutText" Style="{StaticResource BodySmallText}" Foreground="{ThemeResource Ink3Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource NotepadSurfaceBrush}" BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
        <StackPanel Spacing="6">
          <TextBlock Style="{StaticResource EyebrowTinyText}" Text="UNOFEATURES (CSPROJ)" />
          <TextBlock x:Name="UnoFeaturesText" Style="{StaticResource MonoBodyText}" Foreground="{ThemeResource Ink2Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Architecture blueprint canvas -->
    <Border Background="{ThemeResource NotepadSurfaceBrush}" CornerRadius="8" Padding="0">
      <diagrams:ArchitectureBlueprintView />
    </Border>

    <!-- Solution tree code block -->
    <Border Background="{ThemeResource NotepadSurfaceBrush}"
            BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1"
            CornerRadius="6" Padding="0" Margin="0,18,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="36" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{ThemeResource PanelBrush}" CornerRadius="6,6,0,0">
          <Grid Padding="14,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource MonoLabelText}" Text="solution-tree.txt" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Style="{StaticResource EyebrowTinyText}" Text="GENERATED FROM CANVAS" VerticalAlignment="Center" />
          </Grid>
        </Border>
        <TextBlock x:Name="SolutionTreeText"
                   Grid.Row="1"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="12"
                   LineHeight="20"
                   Padding="16,12"
                   Foreground="{ThemeResource Ink2Brush}" />
      </Grid>
    </Border>

    <!-- Annotation -->
    <Border BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1,0,0,0"
            Padding="16,2,0,0" Margin="0,28,0,12">
      <StackPanel Spacing="4">
        <TextBlock Style="{StaticResource EyebrowTinyText}" Text="WHY THIS MATTERS" />
        <TextBlock x:Name="WhyThisMattersText" Style="{StaticResource AnnotationText}" />
      </StackPanel>
    </Border>
    <layers:ComposerFooter Margin="0,28,0,0" />
  </StackPanel>
</UserControl>
