<UserControl x:Class="Composer.Presentation.Controls.ReferenceScreenshotPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:p="using:Composer.Presentation">

  <UserControl.Resources>
    <p:FilePathToImageSourceConverter x:Key="PathToImage" />
  </UserControl.Resources>

  <StackPanel Spacing="12">

    <TextBlock Style="{StaticResource MonoLabelText}" Text="REFERENCES" />

    <Border AllowDrop="True"
            DragOver="OnDragOver"
            Drop="OnDrop"
            Background="{ThemeResource PanelBrush}"
            BorderBrush="{ThemeResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20"
            MinHeight="80">
      <Grid>
        <StackPanel x:Name="DefaultReferencesContent"
                    Spacing="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <TextBlock Style="{StaticResource AnnotationText}"
                     Text="Drop screenshots, wireframes, or mockups to seed UX and Design from your vision."
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     MaxWidth="520" />
          <TextBlock Style="{StaticResource EyebrowTinyText}"
                     Foreground="{ThemeResource Ink4Brush}"
                     Text="Accepting the intent overview sends these references into UX flow and design-token generation."
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     MaxWidth="520" />
          <Button Content="Upload images"
                  HorizontalAlignment="Center"
                  Style="{StaticResource LinkButtonStyle}"
                  Click="OnUploadImagesClicked" />
        </StackPanel>

        <StackPanel x:Name="PlatformReferencesContent"
                    Spacing="12"
                    Visibility="Collapsed">
          <TextBlock Style="{StaticResource AnnotationText}"
                     Text="Drop screenshots, wireframes, or mockups into the matching preview frame."
                     TextWrapping="Wrap"
                     TextAlignment="Center" />
          <StackPanel x:Name="PlatformFrameHost"
                      Orientation="Horizontal"
                      Spacing="12"
                      HorizontalAlignment="Center" />
          <Button Content="Upload images"
                  HorizontalAlignment="Center"
                  Style="{StaticResource LinkButtonStyle}"
                  Click="OnUploadImagesClicked" />
        </StackPanel>
      </Grid>
    </Border>

    <ItemsRepeater ItemsSource="{Binding ReferenceScreenshotPaths}">
      <ItemsRepeater.Layout>
        <StackLayout Orientation="Horizontal" Spacing="8" />
      </ItemsRepeater.Layout>
      <ItemsRepeater.ItemTemplate>
        <DataTemplate>
          <Grid Width="80" Height="80">
            <Border Background="{ThemeResource PanelBrush}"
                    BorderBrush="{ThemeResource HairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
              <Image Source="{Binding Converter={StaticResource PathToImage}}"
                     Stretch="UniformToFill" />
            </Border>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    Width="22"
                    Height="22"
                    MinWidth="22"
                    MinHeight="22"
                    Padding="0"
                    CornerRadius="6"
                    Content="×"
                    FontSize="13"
                    FontWeight="SemiBold"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Foreground="{ThemeResource InkBrush}"
                    Background="{ThemeResource NotepadSurfaceBrush}"
                    BorderBrush="{ThemeResource HairlineBrush}"
                    BorderThickness="1"
                    Command="{Binding DataContext.RemoveReferenceScreenshot, ElementName=Root}"
                    CommandParameter="{Binding}" />
          </Grid>
        </DataTemplate>
      </ItemsRepeater.ItemTemplate>
    </ItemsRepeater>

  </StackPanel>
</UserControl>
