<UserControl x:Class="Composer.Presentation.Diagrams.ArchitectureBlueprintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="using:Composer.Presentation">
  <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center">
    <Canvas Width="800" Height="340">

      <!-- Edges (drawn first so modules sit on top) -->
      <!-- pages → mvux : binds (horizontal) -->
      <Line X1="170" Y1="90" X2="320" Y2="90"
             Stroke="{ThemeResource Ink3Brush}" StrokeThickness="1"
            StrokeDashArray="4 3" />
      <Border Canvas.Left="219" Canvas.Top="82" Width="52" Height="16"
              Background="{ThemeResource NotepadSurfaceBrush}" CornerRadius="2"
              HorizontalAlignment="Center">
        <TextBlock Text="binds" FontStyle="Italic" FontSize="10"
                   Foreground="{ThemeResource Ink3Brush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- pages → nav : requests (vertical) -->
      <Line X1="110" Y1="112" X2="110" Y2="208"
             Stroke="{ThemeResource Ink3Brush}" StrokeThickness="1"
            StrokeDashArray="4 3" />
      <Border Canvas.Left="80" Canvas.Top="152" Width="60" Height="16"
              Background="{ThemeResource NotepadSurfaceBrush}" CornerRadius="2">
        <TextBlock Text="requests" FontStyle="Italic" FontSize="10"
                   Foreground="{ThemeResource Ink3Brush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- mvux → services : consumes (vertical) -->
      <Line X1="380" Y1="112" X2="380" Y2="208"
             Stroke="{ThemeResource Ink3Brush}" StrokeThickness="1"
            StrokeDashArray="4 3" />
      <Border Canvas.Left="350" Canvas.Top="152" Width="60" Height="16"
              Background="{ThemeResource NotepadSurfaceBrush}" CornerRadius="2">
        <TextBlock Text="consumes" FontStyle="Italic" FontSize="10"
                   Foreground="{ThemeResource Ink3Brush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- services → http : calls (diagonal, center to center) -->
      <Line X1="440" Y1="230" X2="590" Y2="90"
             Stroke="{ThemeResource Ink3Brush}" StrokeThickness="1"
            StrokeDashArray="4 3" />
      <Border Canvas.Left="489" Canvas.Top="152" Width="52" Height="16"
              Background="{ThemeResource NotepadSurfaceBrush}" CornerRadius="2">
        <TextBlock Text="calls" FontStyle="Italic" FontSize="10"
                   Foreground="{ThemeResource Ink3Brush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- services → storage : persists (horizontal) -->
      <Line X1="440" Y1="230" X2="590" Y2="230"
             Stroke="{ThemeResource Ink3Brush}" StrokeThickness="1"
            StrokeDashArray="4 3" />
      <Border Canvas.Left="489" Canvas.Top="222" Width="52" Height="16"
              Background="{ThemeResource NotepadSurfaceBrush}" CornerRadius="2">
        <TextBlock Text="persists" FontStyle="Italic" FontSize="10"
                   Foreground="{ThemeResource Ink3Brush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- ── Modules ───────────────────────────────────────────── -->
      <!-- Pages — ink -->
      <Border Canvas.Left="50" Canvas.Top="68" Width="120" Height="44"
              CornerRadius="6" BorderThickness="1.3"
              m:Motion.Lean="True"
              BorderBrush="{ThemeResource InkBrush}"
              Background="{ThemeResource NotepadSurfaceBrush}">
        <TextBlock Text="Pages" FontSize="11" FontWeight="Medium"
                   Foreground="{ThemeResource InkBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- Navigation — ink -->
      <Border Canvas.Left="50" Canvas.Top="208" Width="120" Height="44"
              CornerRadius="6" BorderThickness="1.3"
              m:Motion.Lean="True"
              BorderBrush="{ThemeResource InkBrush}"
              Background="{ThemeResource NotepadSurfaceBrush}">
        <TextBlock Text="Navigation" FontSize="11" FontWeight="Medium"
                   Foreground="{ThemeResource InkBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- State (MVUX) — indigo accent -->
      <Border Canvas.Left="320" Canvas.Top="68" Width="120" Height="44"
              CornerRadius="6" BorderThickness="1.3"
              m:Motion.Lean="True"
              BorderBrush="{ThemeResource InfoBrush}"
              Background="{ThemeResource NotepadSurfaceBrush}">
        <TextBlock Text="State (MVUX)" FontSize="11" FontWeight="Medium"
                   Foreground="{ThemeResource InfoBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- Services — ink2 -->
      <Border Canvas.Left="320" Canvas.Top="208" Width="120" Height="44"
              CornerRadius="6" BorderThickness="1.3"
              m:Motion.Lean="True"
              BorderBrush="{ThemeResource Ink2Brush}"
              Background="{ThemeResource NotepadSurfaceBrush}">
        <TextBlock Text="Services" FontSize="11" FontWeight="Medium"
                   Foreground="{ThemeResource Ink2Brush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- HTTP (Kiota) - accent -->
      <Border Canvas.Left="590" Canvas.Top="68" Width="120" Height="44"
              CornerRadius="6" BorderThickness="1.3"
              m:Motion.Lean="True"
              BorderBrush="{ThemeResource ActionBrush}"
              Background="{ThemeResource NotepadSurfaceBrush}">
        <TextBlock Text="HTTP (Kiota)" FontSize="11" FontWeight="Medium"
                   Foreground="{ThemeResource ActionBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <!-- Storage — ink2 -->
      <Border Canvas.Left="590" Canvas.Top="208" Width="120" Height="44"
              CornerRadius="6" BorderThickness="1.3"
              m:Motion.Lean="True"
              BorderBrush="{ThemeResource Ink2Brush}"
              Background="{ThemeResource NotepadSurfaceBrush}">
        <TextBlock Text="Storage" FontSize="11" FontWeight="Medium"
                   Foreground="{ThemeResource Ink2Brush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

    </Canvas>
  </Viewbox>
</UserControl>
